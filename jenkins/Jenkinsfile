@Library('shared-library@main') _
pipeline {
  agent {
    kubernetes {
      cloud 'fngn-k8s-core-west-1'
    }
  }
  options {
    buildDiscarder(logRotator(artifactDaysToKeepStr: '', artifactNumToKeepStr: '5', daysToKeepStr: '', numToKeepStr: '5'))
    timeout(time: 15, unit: 'MINUTES')
    // This is required if you want to clean before build
    skipDefaultCheckout(true)
    gitLabConnection('Gitlab.com')
  }
  environment {
    project = "aem"
    branchName = "develop"
  }
  stages {
    stage ('Setup') {
      steps {
        // Clean dir before build
        cleanWs(
          deleteDirs: true
        )
        // SCM
        git branch: 'develop', credentialsId: 'Gitlab-SaaS-Ssh-Key', url: 'git@gitlab.com:FNGN/aem/efe-aem.git'
      }
    }
    stage ('Checkmarx SCA') {
      steps {
        echo "run checkmarxSCA placeholder"
      }
    }
    stage ('Checkmarx SAST') {
      steps {
        echo "run checkmarxSAST placeholder"
      }
    }
    stage ('Adobe Sync') {
      environment {
        AEM_SYNC_USER_NAME = "svc-a-e-c-aem-edelmanfinancialengines-com"
        AEM_SYNC_USER_ACCESS_TOKEN = credentials('jenkins/aem-sync-user-access-token')
      }
      steps {
        echo "Sync the ${branchName} branch to Adobe Git"
        sshagent(credentials: ['Gitlab-SaaS-Ssh-Key']) {
          sh '''
            git remote add cmgit https://$AEM_SYNC_USER_NAME:$AEM_SYNC_USER_ACCESS_TOKEN@git.cloudmanager.adobe.com/financialengines/FinancialEnginesSites-p91602-uk32541/
            git remote -v
            git checkout ${branchName}
            git branch -l
            git pull origin ${branchName}
            git push cmgit ${branchName}
          '''
        }
      }
    }
  }
  post {
    always {
      echo "Pipeline completed"
      cleanWs(
        deleteDirs: false
      )
    }
    // Email Ext plugin:
    failure {
      emailext (
          subject: "FAILED: Job '${env.JOB_NAME} [Build #${env.BUILD_NUMBER}]'",
          body: """<p>FAILED: Job '${env.JOB_NAME} [${env.BUILD_NUMBER}]':</p>
            <p>Check console output at &QUOT;<a href='${env.BUILD_URL}'>${env.JOB_NAME} [${env.BUILD_NUMBER}]</a>&QUOT;</p>""",
          to: "devtools@edelmanfinancialengines.com",
          from: "devtools@edelmanfinancialengines.com",
          mimeType: 'text/html'
        )
    }
  }
}
