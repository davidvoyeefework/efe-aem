<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:isCheckedOut="{Boolean}false"
    jcr:primaryType="cq:WorkflowModel"
    sling:resourceType="cq/workflow/components/model"
    description="Workflow to publish the content fragment"
    title="EFE Publish Content Fragment ">
    <metaData
        cq:generatingPage="/conf/global/settings/workflow/models/efe-publish-content-fragment/jcr:content"
        jcr:primaryType="nt:unstructured"/>
    <nodes jcr:primaryType="nt:unstructured">
        <node0
            jcr:primaryType="cq:WorkflowNode"
            title="Start"
            type="START">
            <metaData jcr:primaryType="nt:unstructured"/>
        </node0>
        <node1
            jcr:primaryType="cq:WorkflowNode"
            description="Validate the Content Fragment"
            title="Validate the Content Fragment"
            type="PARTICIPANT">
            <metaData
                jcr:primaryType="nt:unstructured"
                PARTICIPANT="EFE AEM Assets CF Approvers"/>
        </node1>
        <node2
            jcr:primaryType="cq:WorkflowNode"
            title="OR_SPLIT"
            type="OR_SPLIT">
            <metaData jcr:primaryType="nt:unstructured"/>
        </node2>
        <node3
            jcr:primaryType="cq:WorkflowNode"
            title="OR_JOIN"
            type="OR_JOIN">
            <metaData jcr:primaryType="nt:unstructured"/>
        </node3>
        <node4
            jcr:primaryType="cq:WorkflowNode"
            description="Reject the Content Fragment"
            title="Reject the Content Fragment"
            type="PARTICIPANT">
            <metaData
                jcr:primaryType="nt:unstructured"
                PARTICIPANT="EFE Assets Content Fragment Contributors"/>
        </node4>
        <node5
            jcr:primaryType="cq:WorkflowNode"
            description="The Version to be activated/replicated is created"
            title="Create Version and Publish"
            type="PROCESS">
            <metaData
                jcr:primaryType="nt:unstructured"
                PROCESS="com.day.cq.wcm.workflow.process.CreateVersionProcess"
                PROCESS_AUTO_ADVANCE="true"/>
        </node5>
        <node6
            jcr:primaryType="cq:WorkflowNode"
            description="Activates the page."
            title="Activate Page"
            type="PROCESS">
            <metaData
                jcr:primaryType="nt:unstructured"
                PROCESS="com.day.cq.wcm.workflow.process.ActivatePageProcess"
                PROCESS_AUTO_ADVANCE="true"/>
        </node6>
        <node7
            jcr:primaryType="cq:WorkflowNode"
            title="End"
            type="END">
            <metaData jcr:primaryType="nt:unstructured"/>
        </node7>
    </nodes>
    <transitions jcr:primaryType="nt:unstructured">
        <node0_x0023_node1
            jcr:primaryType="cq:WorkflowTransition"
            from="node0"
            rule="\0"
            to="node1">
            <metaData jcr:primaryType="nt:unstructured"/>
        </node0_x0023_node1>
        <node1_x0023_node2
            jcr:primaryType="cq:WorkflowTransition"
            from="node1"
            to="node2">
            <metaData jcr:primaryType="nt:unstructured"/>
        </node1_x0023_node2>
        <node2_x0023_node4
            jcr:primaryType="cq:WorkflowTransition"
            from="node2"
            rule="\0"
            to="node4">
            <metaData
                jcr:primaryType="nt:unstructured"
                isDefault="false"/>
        </node2_x0023_node4>
        <node4_x0023_node3
            jcr:primaryType="cq:WorkflowTransition"
            from="node4"
            to="node3">
            <metaData jcr:primaryType="nt:unstructured"/>
        </node4_x0023_node3>
        <node2_x0023_node5
            jcr:primaryType="cq:WorkflowTransition"
            from="node2"
            rule="\0"
            to="node5">
            <metaData
                jcr:primaryType="nt:unstructured"
                isDefault="true"/>
        </node2_x0023_node5>
        <node5_x0023_node6
            jcr:primaryType="cq:WorkflowTransition"
            from="node5"
            rule="\0"
            to="node6">
            <metaData jcr:primaryType="nt:unstructured"/>
        </node5_x0023_node6>
        <node6_x0023_node3
            jcr:primaryType="cq:WorkflowTransition"
            from="node6"
            to="node3">
            <metaData jcr:primaryType="nt:unstructured"/>
        </node6_x0023_node3>
        <node3_x0023_node7
            jcr:primaryType="cq:WorkflowTransition"
            from="node3"
            to="node7">
            <metaData jcr:primaryType="nt:unstructured"/>
        </node3_x0023_node7>
    </transitions>
</jcr:root>
