<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0"
    jcr:primaryType="sling:OrderedFolder"
    jcr:title="EFE-ContentFragmentSchema">
    <jcr:content jcr:primaryType="nt:unstructured"/>
    <items jcr:primaryType="nt:unstructured">
        <tabs
            jcr:primaryType="nt:unstructured"
            sling:resourceType="granite/ui/components/coral/foundation/tabs"
            size="L">
            <items jcr:primaryType="nt:unstructured">
                <tab1
                    granite:rel="aem-assets-metadata-form-tab"
                    jcr:primaryType="nt:unstructured"
                    jcr:title="Basic"
                    sling:resourceType="granite/ui/components/coral/foundation/container"
                    listOrder="0">
                    <granite:data
                        jcr:primaryType="nt:unstructured"
                        tabid="132a0788-7a84-4143-ac2b-3ecbb502d3a1"/>
                    <items jcr:primaryType="nt:unstructured">
                        <col1
                            granite:rel="aem-assets-metadata-form-column"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            listOrder="0">
                            <items jcr:primaryType="nt:unstructured">
                                <title
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="dam/gui/components/admin/schemafield"
                                    emptyText="Enter title"
                                    fieldLabel="Title"
                                    name="./jcr:content/jcr:title"
                                    resourceType="granite/ui/components/coral/foundation/form/textfield">
                                    <granite:data
                                        jcr:primaryType="nt:unstructured"
                                        cq-msm-lockable="./jcr:title"
                                        metaType="text"
                                        requiredCascading="default"
                                        visibilityCascading="default"/>
                                </title>
                                <description
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="dam/gui/components/admin/schemafield"
                                    emptyText="Enter description"
                                    fieldLabel="Description"
                                    name="./jcr:content/jcr:description"
                                    resourceType="granite/ui/components/coral/foundation/form/textfield">
                                    <granite:data
                                        jcr:primaryType="nt:unstructured"
                                        cq-msm-lockable="./jcr:description"
                                        metaType="text"
                                        requiredCascading="default"
                                        visibilityCascading="default"/>
                                </description>
                                <create_time
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="dam/gui/components/admin/schemafield"
                                    displayedFormat="YYYY-MM-DD HH:mm"
                                    fieldLabel="Created"
                                    name="./jcr:created"
                                    readOnly="{Boolean}true"
                                    resourceType="granite/ui/components/coral/foundation/form/datepicker"
                                    type="datetime">
                                    <granite:data
                                        jcr:primaryType="nt:unstructured"
                                        cq-msm-lockable="./jcr:created"
                                        metaType="datepicker"
                                        requiredCascading="default"
                                        typeHint="Date"
                                        visibilityCascading="default"/>
                                </create_time>
                            </items>
                        </col1>
                        <col2
                            granite:rel="aem-assets-metadata-form-column"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            listOrder="1"
                            oice-options="on">
                            <items jcr:primaryType="nt:unstructured">
                                <_x0031_679875669977
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="dam/gui/components/admin/schemafield"
                                    emptyText="Select Option"
                                    fieldLabel="Portfolio"
                                    jsonPath="/apps/efe/utils/dropdown/portfolio.json"
                                    name="./jcr:content/metadata/efe:portfolio"
                                    resourceType="dam/gui/coral/components/admin/schemaforms/formbuilder/formfields/v2/metadataselect">
                                    <granite:data
                                        jcr:primaryType="nt:unstructured"
                                        cq-msm-lockable="./metadata/efe:portfolio"
                                        metaType="dropdown"
                                        requiredCascading="default"/>
                                    <items jcr:primaryType="nt:unstructured"/>
                                </_x0031_679875669977>
                                <_x0031_679875698652
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="dam/gui/components/admin/schemafield"
                                    emptyText="Select Option"
                                    fieldLabel="Record Keeper"
                                    jsonPath="/apps/efe/utils/dropdown/record_keeper.json"
                                    multiple="true"
                                    name="./jcr:content/metadata/efe:recordKeeper"
                                    resourceType="dam/gui/coral/components/admin/schemaforms/formbuilder/formfields/v2/metadataselect">
                                    <granite:data
                                        jcr:primaryType="nt:unstructured"
                                        cq-msm-lockable="./metadata/efe:recordKeeper"
                                        metaType="dropdown"
                                        requiredCascading="default"/>
                                    <items jcr:primaryType="nt:unstructured"/>
                                </_x0031_679875698652>
                                <_x0031_679875763748
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="dam/gui/components/admin/schemafield"
                                    emptyText="Select Option"
                                    fieldLabel="Employer"
                                    jsonPath="/apps/efe/utils/dropdown/employer.json"
                                    multiple="true"
                                    name="./jcr:content/metadata/efe:provider"
                                    resourceType="dam/gui/coral/components/admin/schemaforms/formbuilder/formfields/v2/metadataselect">
                                    <granite:data
                                        jcr:primaryType="nt:unstructured"
                                        cq-msm-lockable="./metadata/efe:provider"
                                        metaType="dropdown"
                                        requiredCascading="default"/>
                                    <items jcr:primaryType="nt:unstructured"/>
                                </_x0031_679875763748>
                                <tags
                                    cq:showOnCreate="{Boolean}true"
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="dam/gui/components/admin/schemafield"
                                    cq-msm-lockable="cq:tags"
                                    fieldLabel="Tags"
                                    metaType="tags"
                                    multiple="true"
                                    name="./jcr:content/metadata/cq:tags"
                                    resourceType="cq/gui/components/coral/common/form/tagfield">
                                    <granite:data
                                        jcr:primaryType="nt:unstructured"
                                        cq-msm-lockable="./metadata/cq:tags"
                                        visibilityCascading="default"/>
                                </tags>
                            </items>
                        </col2>
                    </items>
                </tab1>
            </items>
        </tabs>
    </items>
</jcr:root>
