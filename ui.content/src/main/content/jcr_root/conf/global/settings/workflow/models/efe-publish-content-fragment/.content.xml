<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:designPath="/libs/settings/wcm/designs/default"
        cq:template="/libs/cq/workflow/templates/model"
        jcr:primaryType="cq:PageContent"
        jcr:title="EFE Publish Content Fragment"
        sling:resourceType="cq/workflow/components/pages/model">
        <flow
            jcr:primaryType="nt:unstructured"
            sling:resourceType="foundation/components/parsys">
            <participant
                jcr:description="Approve the CF to publish or Reject and send it back to the contributors."
                jcr:primaryType="nt:unstructured"
                jcr:title="Validate the Content Fragment"
                sling:resourceType="cq/workflow/components/model/participant">
                <metaData
                    jcr:primaryType="nt:unstructured"
                    PARTICIPANT="EFE AEM Assets CF Approvers"/>
            </participant>
            <or
                jcr:primaryType="nt:unstructured"
                sling:resourceType="cq/workflow/components/model/or"
                branches="2"
                branchName1="Branch 1"
                branchName2="Branch 2"
                branchOrder="[0,1]"
                default2="true"
                orSplit="true">
                <_x0031_
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="cq/flow/components/parsys">
                    <participant
                        jcr:description="Complete to end the workflow or step back to approvers."
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Reject the Content Fragment"
                        sling:resourceType="cq/workflow/components/model/participant">
                        <metaData
                            jcr:primaryType="nt:unstructured"
                            PARTICIPANT="EFE Assets Content Fragment Contributors"/>
                    </participant>
                </_x0031_>
                <_x0032_
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="cq/flow/components/parsys">
                    <createversion
                        jcr:description="The Version to be activated/replicated is created"
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Create Version and Publish"
                        sling:resourceType="cq/workflow/components/model/process">
                        <metaData
                            jcr:primaryType="nt:unstructured"
                            PROCESS="com.day.cq.wcm.workflow.process.CreateVersionProcess"
                            PROCESS_AUTO_ADVANCE="true"/>
                    </createversion>
                    <activate
                        jcr:description="Activates the page."
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Activate Page"
                        sling:resourceType="cq/workflow/components/model/process">
                        <metaData
                            jcr:primaryType="nt:unstructured"
                            PROCESS="com.day.cq.wcm.workflow.process.ActivatePageProcess"
                            PROCESS_AUTO_ADVANCE="true"/>
                    </activate>
                </_x0032_>
            </or>
        </flow>
    </jcr:content>
</jcr:root>
