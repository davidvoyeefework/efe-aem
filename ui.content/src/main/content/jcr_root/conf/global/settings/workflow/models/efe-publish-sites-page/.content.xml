<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:designPath="/libs/settings/wcm/designs/default"
        cq:template="/libs/cq/workflow/templates/model"
        jcr:primaryType="cq:PageContent"
        jcr:title="EFE PUBLISH SITES PAGE"
        sling:resourceType="cq/workflow/components/pages/model">
        <flow
            jcr:primaryType="nt:unstructured"
            sling:resourceType="foundation/components/parsys">
            <participant
                jcr:description="Review the page"
                jcr:primaryType="nt:unstructured"
                jcr:title="Review the page"
                sling:resourceType="cq/workflow/components/model/participant">
                <metaData
                    jcr:primaryType="nt:unstructured"
                    PARTICIPANT="EFE AEM Sites Reviewers"/>
            </participant>
            <or
                jcr:primaryType="nt:unstructured"
                sling:resourceType="cq/workflow/components/model/or"
                branches="2"
                branchName1="Reject"
                branchName2="Approve"
                branchOrder="[0,1]"
                orSplit="true">
                <_x0031_
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="cq/flow/components/parsys">
                    <process
                        jcr:description="Request rejected by the reviewer."
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Reject and send back to initiator"
                        sling:resourceType="cq/workflow/components/model/process">
                        <metaData
                            jcr:primaryType="nt:unstructured"
                            PROCESS="com.efe.core.workflow.InboxNotificationSenderImpl"
                            PROCESS_AUTO_ADVANCE="true"/>
                    </process>
                </_x0031_>
                <_x0032_
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="cq/flow/components/parsys">
                    <dynamic_participant
                        jcr:description="Request approved by the reviewer group."
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Approve and send to approver group"
                        sling:resourceType="cq/workflow/components/model/dynamic_participant">
                        <metaData
                            jcr:primaryType="nt:unstructured"
                            DYNAMIC_PARTICIPANT="com.efe.core.workflow.WorkflowParticipantChooserImpl"
                            PROCESS_ARGS="Sites Approver"/>
                    </dynamic_participant>
                    <or
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="cq/workflow/components/model/or"
                        branches="2"
                        branchName1="Reject"
                        branchName2="Approve"
                        branchOrder="[0,1]"
                        orSplit="true">
                        <_x0031_
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="cq/flow/components/parsys">
                            <process
                                jcr:description="Request rejected by the approver."
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Reject"
                                sling:resourceType="cq/workflow/components/model/process">
                                <metaData
                                    jcr:primaryType="nt:unstructured"
                                    PROCESS="com.efe.core.workflow.InboxNotificationSenderImpl"
                                    PROCESS_AUTO_ADVANCE="true"/>
                            </process>
                        </_x0031_>
                        <_x0032_
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="cq/flow/components/parsys">
                            <process
                                jcr:description="Request approved by the approver."
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Approve"
                                sling:resourceType="cq/workflow/components/model/process">
                                <metaData
                                    jcr:primaryType="nt:unstructured"
                                    PROCESS="com.efe.core.workflow.InboxNotificationSenderImpl"
                                    PROCESS_AUTO_ADVANCE="true"/>
                            </process>
                        </_x0032_>
                    </or>
                </_x0032_>
            </or>
        </flow>
    </jcr:content>
</jcr:root>
