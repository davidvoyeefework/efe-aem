<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:deviceGroups="[mobile/groups/responsive]"
        cq:template="/conf/efe/settings/wcm/templates/fe-header-and-footer"
        jcr:primaryType="cq:PageContent"
        sling:resourceType="efe/fe-components/structure/fe-page">
        <root
            jcr:primaryType="nt:unstructured"
            sling:resourceType="efe/components/container"
            layout="responsiveGrid">
            <experiencefragment-header
                jcr:primaryType="nt:unstructured"
                sling:resourceType="efe/components/experiencefragment"
                fragmentVariationPath="/content/experience-fragments/fe/us/en/site/direct-sponsor-landing-pages-header/master"/>
            <container
                jcr:primaryType="nt:unstructured"
                sling:resourceType="efe/components/container"
                id="main"
                layout="responsiveGrid">
                <container
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="efe/components/container"
                    editable="{Boolean}true"
                    layout="responsiveGrid"/>
            </container>
            <experiencefragment_footer
                jcr:primaryType="nt:unstructured"
                sling:resourceType="efe/components/experiencefragment"
                fragmentVariationPath="/content/experience-fragments/fe/us/en/site/dynamic-footer/master"/>
        </root>
        <cq:responsive jcr:primaryType="nt:unstructured">
            <breakpoints jcr:primaryType="nt:unstructured">
                <phone
                    jcr:primaryType="nt:unstructured"
                    title="Smaller Screen"
                    width="{Long}768"/>
                <tablet
                    jcr:primaryType="nt:unstructured"
                    title="Tablet"
                    width="{Long}1200"/>
            </breakpoints>
        </cq:responsive>
    </jcr:content>
</jcr:root>
