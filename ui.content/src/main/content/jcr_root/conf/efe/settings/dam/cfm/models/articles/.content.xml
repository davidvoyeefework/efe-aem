<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Template"
    allowedPaths="[/content/entities(/.*)?]"
    ranking="{Long}100">
    <jcr:content
        cq:scaffolding="/conf/efe/settings/dam/cfm/models/articles/jcr:content/model"
        cq:templateType="/libs/settings/dam/cfm/model-types/fragment"
        jcr:primaryType="cq:PageContent"
        jcr:title="Articles"
        sling:resourceSuperType="dam/cfm/models/console/components/data/entity"
        sling:resourceType="dam/cfm/models/console/components/data/entity/default"
        status="enabled">
        <metadata jcr:primaryType="nt:unstructured"/>
        <model
            cq:targetPath="/content/entities"
            jcr:primaryType="cq:PageContent"
            sling:resourceType="wcm/scaffolding/components/scaffolding"
            dataTypesConfig="/mnt/overlay/settings/dam/cfm/models/formbuilderconfig/datatypes"
            maxGeneratedOrder="20">
            <cq:dialog
                jcr:primaryType="nt:unstructured"
                sling:resourceType="cq/gui/components/authoring/dialog">
                <content
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                    <items
                        jcr:primaryType="nt:unstructured"
                        maxGeneratedOrder="20">
                        <title
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/admin/components/authoring/contenteditor/multieditor"
                            cfm-element="Title"
                            checked="false"
                            default-mime-type="text/html"
                            listOrder="2"
                            metaType="text-multi"
                            name="title"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string/multiline"/>
                        <subtitle
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/admin/components/authoring/contenteditor/multieditor"
                            cfm-element="Subtitle"
                            checked="false"
                            default-mime-type="text/html"
                            listOrder="2"
                            metaType="text-multi"
                            name="subtitle"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string/multiline"/>
                        <articleSummary
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/admin/components/authoring/contenteditor/multieditor"
                            cfm-element="Article Summary"
                            checked="false"
                            default-mime-type="text/html"
                            fieldDescription="Article Summary"
                            listOrder="2"
                            metaType="text-multi"
                            name="articleSummary"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string/multiline"/>
                        <body
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/models/editor/components/contentreference"
                            fieldLabel="Article Body"
                            filter="hierarchy"
                            listOrder="8"
                            metaType="reference"
                            name="body"
                            nameSuffix="contentReference"
                            renderReadOnly="false"
                            rootPath="/content/experience-fragments/efe"
                            showEmptyInReadOnly="true"
                            showThumbnail="false"
                            valueType="string/reference">
                            <granite:data
                                jcr:primaryType="nt:unstructured"
                                thumbnail-validation="cfm.validation.thumbnail.show"/>
                        </body>
                        <heroImage
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/models/editor/components/contentreference"
                            fieldDescription="Image that will appear as the hero image at top of page"
                            fieldLabel="Hero Image"
                            filter="hierarchy"
                            listOrder="8"
                            metaType="reference"
                            name="heroImage"
                            nameSuffix="contentReference"
                            renderReadOnly="false"
                            rootPath="/content/dam/efe"
                            showEmptyInReadOnly="true"
                            showThumbnail="false"
                            validation="cfm.validation.contenttype.image"
                            valueType="string/reference">
                            <granite:data
                                jcr:primaryType="nt:unstructured"
                                thumbnail-validation="cfm.validation.thumbnail.show"/>
                        </heroImage>
                        <authorType
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/admin/components/authoring/contenteditor/multicheckbox"
                            emptyOption="{Boolean}true"
                            fieldDescription="Is Author a Planner?"
                            fieldLabel="Author Type"
                            listOrder="6"
                            metaType="enumeration"
                            name="authorType"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string[]">
                            <optionsmultifield jcr:primaryType="nt:unstructured">
                                <item0
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Regular Author"
                                    fieldValue="Regular Author"/>
                                <item1
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Planner"
                                    fieldValue="Planner"/>
                            </optionsmultifield>
                            <datasource
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="dam/cfm/admin/components/datasources/optionrendererenumeration"
                                variant="default"/>
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </authorType>
                        <author1
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/models/editor/components/fragmentreference/multifield"
                            allowNew="{Boolean}true"
                            fieldDescription="Referenced CF with author info"
                            fieldLabel="Regular Author"
                            filter="hierarchy"
                            fragmentmodelreference="[/conf/efe/settings/dam/cfm/models/authors,/conf/efe/settings/dam/cfm/models/planner]"
                            listOrder="9"
                            metaType="fragment-reference"
                            name="regularAuthor"
                            nameSuffix="contentReference"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string/content-fragment[]">
                            <field
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="dam/cfm/models/editor/components/fragmentreference"
                                fragmentmodelreference="[/conf/efe/settings/dam/cfm/models/authors,/conf/efe/settings/dam/cfm/models/planner]"
                                name="regularAuthor"
                                renderReadOnly="false">
                                <granite:data jcr:primaryType="nt:unstructured"/>
                            </field>
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </author1>
                        <author2
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/models/editor/components/fragmentreference/multifield"
                            allowNew="{Boolean}true"
                            fieldDescription="Referenced CF with author info"
                            fieldLabel="Planner"
                            filter="hierarchy"
                            fragmentmodelreference="[/conf/efe/settings/dam/cfm/models/authors,/conf/efe/settings/dam/cfm/models/planner]"
                            listOrder="9"
                            metaType="fragment-reference"
                            name="planner"
                            nameSuffix="contentReference"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string/content-fragment[]">
                            <field
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="dam/cfm/models/editor/components/fragmentreference"
                                fragmentmodelreference="[/conf/efe/settings/dam/cfm/models/authors,/conf/efe/settings/dam/cfm/models/planner]"
                                name="planner"
                                renderReadOnly="false">
                                <granite:data jcr:primaryType="nt:unstructured"/>
                            </field>
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </author2>
                        <datePublished
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/models/editor/components/datatypes/datepicker"
                            displayedFormat="YYYY-MM-DD HH:mm"
                            emptyText="YYYY-MM-DD HH:mm:ss"
                            fieldLabel="Date Published"
                            listOrder="5"
                            metaType="date"
                            name="datePublished"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            type="datetime"
                            valueFormat="YYYY-MM-DD[T]HH:mm:ss.000Z"
                            valueType="calendar/datetime">
                            <granite:data
                                jcr:primaryType="nt:unstructured"
                                typeHint="Date"/>
                        </datePublished>
                        <dateUpdated
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/models/editor/components/datatypes/datepicker"
                            displayedFormat="YYYY-MM-DD HH:mm"
                            emptyText="YYYY-MM-DD HH:mm:ss"
                            fieldLabel="Date Updated"
                            listOrder="5"
                            metaType="date"
                            name="dateUpdated"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            type="datetime"
                            valueFormat="YYYY-MM-DD[T]HH:mm:ss.000Z"
                            valueType="calendar/datetime">
                            <granite:data
                                jcr:primaryType="nt:unstructured"
                                typeHint="Date"/>
                        </dateUpdated>
                        <disclosure
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/models/editor/components/fragmentreference"
                            allowNew="{Boolean}true"
                            fieldDescription="Reference to Disclosure CF for the page"
                            fieldLabel="Disclosure"
                            filter="hierarchy"
                            fragmentmodelreference="/conf/efe/settings/dam/cfm/models/disclosures"
                            listOrder="9"
                            metaType="fragment-reference"
                            name="disclosure"
                            nameSuffix="contentReference"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string/content-fragment">
                            <field jcr:primaryType="nt:unstructured"/>
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </disclosure>
                        <tags
                            cq:showOnCreate="true"
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="cq/gui/components/coral/common/form/tagfield"
                            autocreateTag="true"
                            fieldLabel="Tags"
                            forceSelection="false"
                            listOrder="7"
                            metaType="tags"
                            multiple="true"
                            name="tags"
                            renderReadOnly="false"
                            required="on"
                            rootPath="/content/cq:tags/efe/content-type"
                            showEmptyInReadOnly="true"
                            valueType="string/tags[]"/>
                    </items>
                </content>
            </cq:dialog>
        </model>
    </jcr:content>
</jcr:root>
