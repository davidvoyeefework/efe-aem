<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Template"
    allowedPaths="[/content/entities(/.*)?]"
    ranking="{Long}100">
    <jcr:content
        cq:lastModified="{Date}2023-03-29T14:37:56.554+05:30"
        cq:lastModifiedBy="admin"
        cq:scaffolding="/conf/efe/settings/dam/cfm/models/category-card/jcr:content/model"
        cq:templateType="/libs/settings/dam/cfm/model-types/fragment"
        jcr:primaryType="cq:PageContent"
        jcr:title="Category Cards"
        sling:resourceSuperType="dam/cfm/models/console/components/data/entity"
        sling:resourceType="dam/cfm/models/console/components/data/entity/default"
        status="enabled">
        <metadata jcr:primaryType="nt:unstructured"/>
        <model
            cq:targetPath="/content/entities"
            jcr:primaryType="cq:PageContent"
            sling:resourceType="wcm/scaffolding/components/scaffolding"
            dataTypesConfig="/mnt/overlay/settings/dam/cfm/models/formbuilderconfig/datatypes"
            maxGeneratedOrder="20">
            <cq:dialog
                jcr:primaryType="nt:unstructured"
                sling:resourceType="cq/gui/components/authoring/dialog">
                <content
                    jcr:lastModified="{Date}2023-03-29T14:37:56.554+05:30"
                    jcr:lastModifiedBy="admin"
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                    <items
                        jcr:primaryType="nt:unstructured"
                        maxGeneratedOrder="20">
                        <cardOrder
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                            fieldDescription="The order of the cards that are shown under each category"
                            fieldLabel="Card Order"
                            listOrder="3"
                            metaType="number"
                            name="cardOrder"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            step="1"
                            valueType="long"
                            typeHint="long">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </cardOrder>
                        <categoryCard
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                            emptyOption="{Boolean}true"
                            fieldDescription="Category that will be used to organize the card within a specific tab"
                            fieldLabel="Category Card"
                            listOrder="6"
                            metaType="enumeration"
                            name="categoryCard"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <optionsmultifield jcr:primaryType="nt:unstructured">
                                <item0
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="New Hire"
                                    fieldValue="New Hire"/>
                                <item1
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Work"
                                    fieldValue="Work"/>
                                <item2
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Personal Life"
                                    fieldValue="Personal Life"/>
                                <item3
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Retirement"
                                    fieldValue="Retirement"/>
                            </optionsmultifield>
                            <datasource
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="dam/cfm/admin/components/datasources/optionrendererenumeration"
                                variant="default"/>
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </categoryCard>
                        <description
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/admin/components/authoring/contenteditor/multieditor"
                            cfm-element="Description"
                            checked="false"
                            default-mime-type="text/html"
                            fieldDescription="Description text for the card"
                            listOrder="2"
                            metaType="text-multi"
                            name="description"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string/multiline"/>
                        <ctaText
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldDescription="Text that will appear as button text"
                            fieldLabel="CTA Text"
                            listOrder="1"
                            maxlength="255"
                            metaType="text-single"
                            name="ctaText"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </ctaText>
                        <ctaLink
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/models/editor/components/contentreference"
                            fieldDescription="Button link"
                            fieldLabel="CTA Link"
                            filter="hierarchy"
                            listOrder="8"
                            metaType="reference"
                            name="ctaLink"
                            nameSuffix="contentReference"
                            renderReadOnly="false"
                            showEmptyInReadOnly="true"
                            showThumbnail="false"
                            valueType="string/reference">
                            <granite:data
                                jcr:primaryType="nt:unstructured"
                                thumbnail-validation="cfm.validation.thumbnail.show"/>
                        </ctaLink>
                        <cardImage
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/models/editor/components/contentreference"
                            fieldDescription="Photo for the card"
                            fieldLabel="Card Image"
                            filter="hierarchy"
                            listOrder="8"
                            metaType="reference"
                            name="cardImage"
                            nameSuffix="contentReference"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            showThumbnail="false"
                            validation="cfm.validation.contenttype.image"
                            valueType="string/reference">
                            <granite:data
                                jcr:primaryType="nt:unstructured"
                                thumbnail-validation="cfm.validation.thumbnail.show"/>
                        </cardImage>
                    </items>
                </content>
            </cq:dialog>
        </model>
    </jcr:content>
</jcr:root>
