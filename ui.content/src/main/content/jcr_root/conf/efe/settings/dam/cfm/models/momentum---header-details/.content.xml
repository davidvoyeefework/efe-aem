<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Template"
    allowedPaths="[/content/entities(/.*)?]"
    ranking="{Long}100">
    <jcr:content
        cq:scaffolding="/conf/efe/settings/dam/cfm/models/momentum---header-details/jcr:content/model"
        cq:templateType="/libs/settings/dam/cfm/model-types/fragment"
        jcr:primaryType="cq:PageContent"
        jcr:title="Momentum - Header Details"
        sling:resourceSuperType="dam/cfm/models/console/components/data/entity"
        sling:resourceType="dam/cfm/models/console/components/data/entity/default"
        status="enabled">
        <metadata jcr:primaryType="nt:unstructured"/>
        <model
            cq:targetPath="/content/entities"
            jcr:primaryType="cq:PageContent"
            sling:resourceType="wcm/scaffolding/components/scaffolding"
            dataTypesConfig="/mnt/overlay/settings/dam/cfm/models/formbuilderconfig/datatypes"
            maxGeneratedOrder="20">
            <cq:dialog
                jcr:primaryType="nt:unstructured"
                sling:resourceType="cq/gui/components/authoring/dialog">
                <content
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                    <items
                        jcr:primaryType="nt:unstructured"
                        maxGeneratedOrder="23">
                        <category
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/select"
                            emptyOption="{Boolean}true"
                            fieldDescription="Category for the types of welcome text"
                            fieldLabel="Category"
                            listOrder="21"
                            metaType="enumeration"
                            name="category"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <optionsmultifield jcr:primaryType="nt:unstructured">
                                <item0
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Generic"
                                    fieldValue="Generic"/>
                                <item1
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="New Hire"
                                    fieldValue="New Hire"/>
                                <item2
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Retirement"
                                    fieldValue="Retirement"/>
                                <item3
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Work"
                                    fieldValue="Work"/>
                                <item4
                                    jcr:primaryType="nt:unstructured"
                                    fieldLabel="Life"
                                    fieldValue="Life"/>
                            </optionsmultifield>
                            <datasource
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="dam/cfm/admin/components/datasources/optionrendererenumeration"
                                variant="default"/>
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </category>
                        <title
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldDescription="Title of the Personalized Text"
                            fieldLabel="Title"
                            listOrder="22"
                            maxlength="255"
                            metaType="text-single"
                            name="title"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string">
                            <granite:data jcr:primaryType="nt:unstructured"/>
                        </title>
                        <subtitle
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="dam/cfm/admin/components/authoring/contenteditor/multieditor"
                            cfm-element="Subtitle"
                            checked="false"
                            default-mime-type="text/html"
                            fieldDescription="Description of text"
                            listOrder="23"
                            metaType="text-multi"
                            name="subtitle"
                            renderReadOnly="false"
                            required="on"
                            showEmptyInReadOnly="true"
                            valueType="string/multiline"/>
                    </items>
                </content>
            </cq:dialog>
        </model>
    </jcr:content>
</jcr:root>
