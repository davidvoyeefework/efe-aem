query getAllCategoryCards{
  momentumCategoryCardsList {
    items {
      _path
      cardOrder
      categoryCard
      description {
        plaintext
      }
      ctaText 
	  	ctaLink {
      	...on  PageRef{
          type
          _path
          _authorUrl
          _publishUrl
      	}
    	}
      cardImage {
        ...on  ImageRef{
          _path
          _authorUrl
          _publishUrl
          width
          height
        }
      }
    }
  }
}
