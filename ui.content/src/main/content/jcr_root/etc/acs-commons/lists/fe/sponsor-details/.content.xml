<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        jcr:primaryType="nt:unstructured"
        jcr:title="Sponsor Details"
        sling:resourceType="acs-commons/components/utilities/genericlist">
        <image
            jcr:primaryType="nt:unstructured"
            fileReference="/apps/acs-commons/components/utilities/genericlist/generic-list.png"/>
        <list jcr:primaryType="nt:unstructured">
            <item0
                jcr:primaryType="nt:unstructured"
                jcr:title="Sponsor Name"
                value="sponsorName|header.sponsorName"/>
            <item1
                jcr:primaryType="nt:unstructured"
                jcr:title="Support Hour"
                value="supportHour|header.supportHour"/>
            <item2
                jcr:primaryType="nt:unstructured"
                jcr:title="Support Phone"
                value="supportPhone|header.supportPhone"/>
            <item3
                jcr:primaryType="nt:unstructured"
                jcr:title="Title"
                value="title|footer.aboutUsPageTitle"/>
        </list>
    </jcr:content>
</jcr:root>
