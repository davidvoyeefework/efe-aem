<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Modal Button"
    sling:resourceType="cq/gui/components/authoring/dialog"
    extraClientlibs="[cq.xf.editor.picker.validator]"
    
>
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
        <items jcr:primaryType="nt:unstructured">
            <column
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">
                    <buttonText
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                            fieldDescription="Text for button to open modal."
                            fieldLabel="Button Modal Text"
                            name="./buttonText"/>
                    <openModalButton 
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldDescription="Open Modal Button" 
                        fieldLabel="Open Modal Button"
                        name="./openModalButton" />
                    <closeModalButton 
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldDescription="Close Modal Button" 
                        fieldLabel="Close Modal Button"
                        name="./closeModalButton" />
                    <embedFragment
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="cq/experience-fragments/editor/components/xffield"
                        name="./embedFragment"
                        fieldLabel="Variation"
                        filter="folderOrVariant"
                        propertyFilter="cq:xfShowInEditor"
                        variant="web"
                        fieldDescription="Choose the experience fragment to use as modal content"
                        />
                    <id
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldDescription="HTML ID attribute to apply to the component."
                        fieldLabel="ID"
                        name="./id"/>
                </items>
            </column>
        </items>
    </content>
</jcr:root>
