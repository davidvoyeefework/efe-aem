<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Header"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <label-links
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Label &amp; Links"
                        sling:orderBefore="cq:styles"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        maximized="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <logo
												jcr:primaryType="nt:unstructured"
												sling:resourceType="cq/gui/components/authoring/dialog/fileupload"
												allowUpload="{Boolean}false"
												fieldDescription="Add header logo here"
												fieldLabel="Logo"
												rootPath="/content/dam/efe"
												name="./logo"/>
                                            <alt
												jcr:primaryType="nt:unstructured"
												sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
												fieldDescription="Add header logo alt text here"
												fieldLabel="Alt Text"
												name="./alt"/>
                                            <logolink
												jcr:primaryType="nt:unstructured"
												sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
												fieldDescription="Add header logo link url here"
												fieldLabel="Logo Link"
												name="./logoLink"
												rootPath="/content/efe"/>
                                            <target
												jcr:primaryType="nt:unstructured"
												sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
												fieldDescription="If checked the link will be opened in a new browser tab."
												name="./logoTarget"
												text="Open header logo in new tab"
												uncheckedValue="_self"
												value="_blank"/>
                                            <ctatitle
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="The text to display on the CTA."
                                                fieldLabel="Planner CTA  Text"
                                                name="./ctaTitle"/>
                                            <ctalink
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="cq/gui/components/coral/common/form/pagefield"
                                                fieldDescription="Link to a content page, external URL or page anchor."
                                                fieldLabel="Planner CTA Link"
                                                name="./ctaLink"
                                                rootPath="/content/efe"/>
                                            <ctatarget
												jcr:primaryType="nt:unstructured"
												sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
												fieldDescription="If checked the link will be opened in a new browser tab."
												name="./ctaTarget"
												text="Open CTA in new tab"
												uncheckedValue="_self"
												value="_blank"/>
											<disablesearch
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                fieldDescription="Disable Search"
                                                name="./disableSearch"
                                                text="Disable Search"
                                                uncheckedValue="false"
                                                value="true"/>
                                            <searchtitle
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="The text to display on the Search button."
                                                fieldLabel="Quick Search Button Text"
                                                name="./searchBtn"/>
                                            <searchboxlabel
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="The label to display on the quick search input box."
                                                fieldLabel="Quick Search Inputbox  Label"
                                                name="./searchLabel"/>
											<disablelogin
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                fieldDescription="Disable Login"
                                                name="./disableLogin"
                                                text="Disable Login"
                                                uncheckedValue="false"
                                                value="true"/>
                                            <logintitle
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="The text to display on the Login Button."
                                                fieldLabel="Login Link title"
                                                name="./loginTitle"/>
                                            <loginlink
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="cq/gui/components/coral/common/form/pagefield"
                                                fieldDescription="Link to a content page, external URL or page anchor."
                                                fieldLabel="Login Link Path"
                                                name="./loginLink"
                                                rootPath="/content/efe"/>
                                            <logintarget
												jcr:primaryType="nt:unstructured"
												sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
												fieldDescription="If checked the link will be opened in a new browser tab."
												name="./loginTarget"
												text="Open Login in new tab"
												uncheckedValue="_self"
												value="_blank"/>
                                            <contacttitle
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="The text to display on the Contact Telephone Number"
                                                fieldLabel="Contact Telephone Number Title"
                                                name="./contactTitle"/>
                                            <contactnumber
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="The Contact Telephone Number"
                                                fieldLabel="Contact Number"
                                                name="./contactNumber"/>
                                            <id
												jcr:primaryType="nt:unstructured"
												sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
												fieldDescription="HTML ID attribute to apply to the component."
												fieldLabel="ID"
												name="./id"/>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </label-links>
                    <headerlist
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Header List"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                    margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <text
												jcr:primaryType="nt:unstructured"
												sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
												fieldLabel="Text for Header Naviagtion"
												fieldDescription="Add Text for Header Navigation"
												composite="{Boolean}true">
                                                <field
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/container"
                                                        name="./headerList">
                                                    <items jcr:primaryType="nt:unstructured">
                                                        <label
															jcr:primaryType="nt:unstructured"
															sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
															fieldDescription="Add label here"
															fieldLabel="Label"
															name="./label"/>
                                                    </items>
                                                </field>
                                            </text>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </headerlist>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
