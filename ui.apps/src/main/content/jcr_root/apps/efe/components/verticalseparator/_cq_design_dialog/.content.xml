<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite0="http://www.w3.org/2001/XMLSchema" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Vertical Separator"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <plugins
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Plugins"
                        sling:resourceType="granite/ui/components/coral/foundation/accordion"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <Paraformat
                                granite0:class="js-cq-IPEPlugin-group"
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Paragraph Styles"
                                sling:resourceType="granite/ui/components/coral/foundation/container"
                                maximized="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <paraformat
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Enable paragraph styles"
                                        sling:resourceType="cq/gui/components/authoring/dialog/inplaceediting/configuration/plugin"
                                        features="*"
                                        name="paraformat"/>
                                    <configWrapper
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="cq/gui/components/authoring/dialog/inplaceediting/configuration/wrapper"
                                        configPath="./rtePlugins/paraformat/formats">
                                        <formats
                                            granite0:class="cq-paragraphstyles"
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                            composite="{Boolean}true"
                                            fieldLabel="Custom Formats">
                                            <field
                                                granite0:class="cq-paragraphstyles-field"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/container"
                                                name="./rtePlugins/paraformat/formats">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <tag
                                                        granite0:class="cq-rte-symbol"
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        emptyText="Element"
                                                        name="tag"/>
                                                    <description
                                                        granite0:class="cq-rte-symbol-description"
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        emptyText="Display text"
                                                        name="description"/>
                                                </items>
                                            </field>
                                        </formats>
                                    </configWrapper>
                                    <mergeOverride
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                        name="./rtePlugins/paraformat/formats/override"
                                        value="{Boolean}true"/>
                                </items>
                                <granite0:data
                                    jcr:primaryType="nt:unstructured"
                                    plugin-root-name="rtePlugins"/>
                            </Paraformat>
                        </items>
                    </plugins>
                    <styletab
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/include"
                        path="/mnt/overlay/cq/gui/components/authoring/dialog/style/tab_design/styletab"/>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
