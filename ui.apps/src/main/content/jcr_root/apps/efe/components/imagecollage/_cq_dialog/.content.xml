<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Image Collage"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs">
                <items jcr:primaryType="nt:unstructured">
                    <primaryimage
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Primary Image"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <primaryimage
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="/libs/granite/ui/components/coral/foundation/form/pathfield"
                                                fieldDescription="Add Primary (Large) image here"
                                                fieldLabel="Primary Image"
                                                name="./primaryImage"
                                                rootPath="/content/dam/efe"/>
                                            <modifier
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="Add modifier here"
                                                fieldLabel="Primary Image Modifier Params"
                                                name="./primaryimgmodifier"/>                                                
                                            <alt
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="Add primary image alt text here"
                                                fieldLabel="Primary Image Alt Text"
                                                name="./primaryImageAltText"/>
                                            <primaryimageposition
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                fieldDescription="Select the Image Position"
                                                fieldLabel="Image Position"
                                                name="./primaryImagePosition">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <objectfit
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Object Fit"
                                                        value="cmp-image--object-fit-cover"/>
                                                    <left
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Left"
                                                        value="cmp-image--position-left"/>
                                                    <right
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Right"
                                                        value="cmp-image--position-right"/>
                                                    <top
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Top"
                                                        value="cmp-image--position-top"/>
                                                    <bottom
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Bottom"
                                                        value="cmp-image--position-bottom"/>
                                                </items>
                                            </primaryimageposition>
                                            <id
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="HTML ID attribute to apply to the component."
                                                fieldLabel="ID"
                                                name="./id"/>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </primaryimage>
                    <secondaryimages
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Secondary Images"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <firstsecondaryimage
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="/libs/granite/ui/components/coral/foundation/form/pathfield"
                                                fieldDescription="Add first Secondary image here"
                                                fieldLabel="First Secondary Image"
                                                name="./firstSecondaryImage"
                                                rootPath="/content/dam/efe"/>
                                            <modifier1
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="Add modifier here"
                                                fieldLabel="First Secondary Image Modifier Params"
                                                name="./firstsecondaryimgmodifier"/>                                                 
                                            <firstsecondaryimagealttext
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="Add first secondary image alt text here"
                                                fieldLabel="First Secondary Image Alt Text"
                                                name="./firstSecondaryImageAltText"/>
                                            <firstsecondaryimageposition
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                fieldDescription="Select the Image Position"
                                                fieldLabel="First Secondary Image Position"
                                                name="./firstSecondaryImagePosition">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <objectfit
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Object Fit"
                                                        value="cmp-image--object-fit-cover"/>
                                                    <left
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Left"
                                                        value="cmp-image--position-left"/>
                                                    <right
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Right"
                                                        value="cmp-image--position-right"/>
                                                    <top
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Top"
                                                        value="cmp-image--position-top"/>
                                                    <bottom
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Bottom"
                                                        value="cmp-image--position-bottom"/>
                                                </items>
                                            </firstsecondaryimageposition>
                                            <secondsecondaryimage
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="/libs/granite/ui/components/coral/foundation/form/pathfield"
                                                fieldDescription="Add second Secondary image here"
                                                fieldLabel="Second Secondary Image"
                                                name="./secondSecondaryImage"
                                                rootPath="/content/dam/efe"/>
                                            <modifier2
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="Add modifier here"
                                                fieldLabel="Second Secondary Image Modifier Params"
                                                name="./secondsecondaryimgmodifier"/>                                                  
                                            <secondsecondaryimagealttext
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="Add second secondary image alt text here"
                                                fieldLabel="Second Secondary Image Alt Text"
                                                name="./secondSecondaryImageAltText"/>
                                            <secondsecondaryimageposition
                                                    jcr:primaryType="nt:unstructured"
                                                    sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                    fieldDescription="Select the Image Position"
                                                    fieldLabel="Second Secondary Image Position"
                                                    name="./secondSecondaryImagePosition">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <objectfit
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Object Fit"
                                                        value="cmp-image--object-fit-cover"/>
                                                    <left
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Left"
                                                        value="cmp-image--position-left"/>
                                                    <right
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Right"
                                                        value="cmp-image--position-right"/>
                                                    <top
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Top"
                                                        value="cmp-image--position-top"/>
                                                    <bottom
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Bottom"
                                                        value="cmp-image--position-bottom"/>
                                                </items>
                                            </secondsecondaryimageposition>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </secondaryimages>
                    <styletab
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/include"
                        path="/mnt/overlay/cq/gui/components/authoring/dialog/style/tab_edit/styletab"/>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
