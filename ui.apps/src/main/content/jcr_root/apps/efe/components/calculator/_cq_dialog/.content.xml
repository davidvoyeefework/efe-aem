<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Calculator"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">

                    <content
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Content"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <calc
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                fieldDescription="Calc Selector"
                                                fieldLabel="Select Calculator Type"
                                                name="./calcType">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <investmentGoal
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Investment Goal Calculator"
                                                        value="https://efe.dinkytown.net/InvestmentVariables.js"/>    
                                                    <mortgage
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Mortgage Calculator"
                                                        value="https://efe.dinkytown.net/MortgageLoan7.js"/> 
                                                    <mortgageRefinance
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Mortgage Refinance Calculator"
                                                        value="https://efe.dinkytown.net/MortgageRefinance.js"/>                                                         
                                                    <seventyTwoT
                                                        jcr:primaryType="nt:unstructured"
                                                        text="72(t) Calculator"
                                                        value="https://efe.dinkytown.net/Retire72T.js"/> 
                                                    <individual401K
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Individual 401(k) Contribution Comparison"
                                                        value="https://efe.dinkytown.net/Individual401kContribution.js"/>
                                                    <pensionVsLumpSum
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Pension vs. Lump Sum Payout Calculator"
                                                        value="https://efe.dinkytown.net/PensionvsLumpSum.js"/>   
                                                    <marginalRate
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Marginal Tax Rate for Federal Taxes"
                                                        value="https://efe.dinkytown.net/TaxMargin.js"/>  
                                                    <savings
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Don't Delay Your Savings!"
                                                        value="https://efe.dinkytown.net/WaitCost.js"/>  
                                                    <disibilityInsurance
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Disability Insurance"
                                                        value="https://efe.dinkytown.net/Disability.js"/>   
                                                    <longTerm
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Long-Term Care Required Savings"
                                                        value="https://efe.dinkytown.net/LongTermCareSavings.js"/>                                                                                                                                                                                                                                                                                                            
                                                           
                                                </items>
                                            </calc>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </content>

                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
