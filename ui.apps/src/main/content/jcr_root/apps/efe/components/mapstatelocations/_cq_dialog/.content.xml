                                                        text="Kentuckyv"
                                                        value="ky"/>
                                                    <la
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Louisiana"
                                                        value="la"/>     
                                                    <md
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Maryland"
                                                        value="md"/>   
                                                    <ma
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Massachusetts"
                                                        value="ma"/>       
                                                    <mi
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Michigan"
                                                        value="mi"/>           
                                                    <mn
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Minnesota"
                                                        value="mn"/>            
                                                    <mo
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Missouri"
                                                        value="mo"/>    
                                                    <ne
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Nebraska"
                                                        value="ne"/>      
                                                    <nj
                                                        jcr:primaryType="nt:unstructured"
                                                        text="New Jersey"
                                                        value="nj"/>   
                                                    <nm
                                                        jcr:primaryType="nt:unstructured"
                                                        text="New Mexico"
                                                        value="nm"/>    
                                                    <nm
                                                        jcr:primaryType="nt:unstructured"
                                                        text="New Mexico"
                                                        value="nm"/>       
                                                    <ny
                                                        jcr:primaryType="nt:unstructured"
                                                        text="New York"
                                                        value="ny"/>   
                                                    <nc
                                                        jcr:primaryType="nt:unstructured"
                                                        text="North Carolina"
                                                        value="nc"/>     
                                                    <oh
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Ohio"
