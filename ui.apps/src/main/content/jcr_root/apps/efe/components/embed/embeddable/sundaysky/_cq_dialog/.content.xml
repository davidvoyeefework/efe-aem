<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
	xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
	xmlns:cq="http://www.day.com/jcr/cq/1.0"
	xmlns:jcr="http://www.jcp.org/jcr/1.0"
	xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
	jcr:primaryType="nt:unstructured"
	sling:resourceType="granite/ui/components/coral/foundation/container">
	<items jcr:primaryType="nt:unstructured">
		<programId 
			jcr:primaryType="nt:unstructured"
			sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
			fieldDescription="Program ID" 
			fieldLabel="Program ID"
			name="./programId" />
		<title 
			jcr:primaryType="nt:unstructured"
			sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
			fieldDescription="SundaySky Title" 
			fieldLabel="SundaySky Title"
			name="./title" />
		<height 
			jcr:primaryType="nt:unstructured"
			sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
			fieldDescription="Enter the iframe min height. Include unit (px, pt, etc)" 
			fieldLabel="Min Height"
			name="./minHeight" />
	</items>
	<granite:data 
		jcr:primaryType="nt:unstructured"
		cmp-embed-dialog-edit-embeddableoptions="true"
		cmp-embed-dialog-edit-showhidetargetvalue="efe/components/embed/embeddable/sundaysky" />
</jcr:root>