<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="WPI Alert"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <content2
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Record Keeper"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <record
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                        fieldDescription="Select Record Keeper"
                                        fieldLabel="Select Record Keeper"
                                        name="./record"
                                        required="{Boolean}true">
                                        <items jcr:primaryType="nt:unstructured">
                                            <fidelity
                                                jcr:primaryType="nt:unstructured"
                                                text="Fidelity"
                                                value="fidelity-wpi-theme"/>
                                            <principle
                                                jcr:primaryType="nt:unstructured"
                                                text="Principal"
                                                value="principal-wpi-theme"/>
                                            <vanguard
                                                jcr:primaryType="nt:unstructured"
                                                text="Vanguard"
                                                value="vanguard-wpi-theme"/>
                                            <alight
                                                jcr:primaryType="nt:unstructured"
                                                text="Alight Solutions"
                                                value="alight-wpi-theme"/>     
                                            <transamerica
                                                jcr:primaryType="nt:unstructured"
                                                text="Transamerica"
                                                value="transamerica-wpi-theme"/>   
                                            <voya
                                                jcr:primaryType="nt:unstructured"
                                                text="Voya"
                                                value="voya-wpi-theme"/>                                                                                                                                          
                                        </items>
                                    </record>
                                    <viewcode
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        fieldDescription="Viewcode"
                                        fieldLabel="Viewcode"
                                        name="./viewcode"/>
                                </items>
                            </columns>
                        </items>
                    </content2>
                    <content
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Content"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <Headline
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="dam/cfm/components/cfpicker"
                                                emptyText="Enter or select Content Fragment"
                                                fieldDescription="Path to the Content Fragment to display Headline."
                                                fieldLabel="Headline"
                                                name="./Headline"
                                                pickerTitle="Select Content Fragment Headline"
                                                rootPath="/content/dam/efe/cf/sub-advised"/>
                                            <Subheadline
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="dam/cfm/components/cfpicker"
                                                emptyText="Enter or select Content Fragment"
                                                fieldDescription="Path to the Content Fragment to display Headline."
                                                fieldLabel="Subheadline"
                                                name="./Subheadline"
                                                pickerTitle="Select Content Fragment Subheadline"
                                                rootPath="/content/dam/efe/cf/sub-advised"/>
                                            <Disclosure
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="dam/cfm/components/cfpicker"
                                                emptyText="Enter or select Content Fragment"
                                                fieldDescription="Path to the Content Fragment to display Disclosures."
                                                fieldLabel="Disclosure"
                                                name="./Disclosure"
                                                pickerTitle="Select Content Fragment Disclosure"
                                                rootPath="/content/dam/efe/cf/sub-advised"/>                                                
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </content>

                    <content0
                        jcr:primaryType="nt:unstructured"
                        jcr:title="CTA and Icon"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <cta
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                        fieldDescription="Call to Action text"
                                        fieldLabel="CTA text"
                                        name="./ctatext"
                                            required="{Boolean}true"                                            
                                            />  
                                    <destination
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                        fieldDescription="CTA Destination"
                                        fieldLabel="CTA Destination"
                                        name="./destination"
                                        required="{Boolean}true">
                                        <datasource
                                            jcr:primaryType="nt:unstructured"
                                            sling:resourceType="acs-commons/components/utilities/genericlist/datasource"
                                            path="/etc/acs-commons/lists/efe/wpi-alert-destination-list"/>
                                    </destination>
                                    <icon
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="/libs/granite/ui/components/coral/foundation/form/pathfield"
                                        fieldDescription="Add Icon"
                                        fieldLabel="Icon"
                                        name="./icon"
                                        rootPath="/content/dam/efe/production/growth-mark/aq_wpi"/>
                                </items>
                            </columns>
                        </items>
                    </content0>

       
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
