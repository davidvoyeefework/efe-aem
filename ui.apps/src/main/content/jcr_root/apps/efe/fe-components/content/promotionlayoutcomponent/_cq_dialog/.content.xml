<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Page top Layout"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <properties
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Properties"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <layoutvariation
                                                granite:class="cq-dialog-dropdown-showhide"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                emptyText="Select"
                                                fieldDescription="Select Variation"
                                                fieldLabel="Select Variation"
                                                name="./variation">
                                                <granite:data
                                                    jcr:primaryType="nt:unstructured"
                                                    cq-dialog-dropdown-showhide-target=".layout-option-listfrom-showhide-target"/>
                                                <items jcr:primaryType="nt:unstructured">
                                                    <variation-1
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Form Right"
                                                        value="variation-1"/>
                                                    <variation-2
                                                        jcr:primaryType="nt:unstructured"
                                                        text="Form Left"
                                                        value="variation-2"/>
                                                </items>
                                            </layoutvariation>
                                            <varitaion-one
                                                granite:class="hide layout-option-listfrom-showhide-target foundation-layout-util-vmargin"
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                                <granite:data
                                                    jcr:primaryType="nt:unstructured"
                                                    showhidetargetvalue="variation-1"/>
                                                <items jcr:primaryType="nt:unstructured">
                                                    <teaservariation
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                        fieldDescription="Select Teaser Hero variation type"
                                                        fieldLabel="Select Teaser Hero variation type"
                                                        name="./teaserVariation">
                                                        <items jcr:primaryType="nt:unstructured">
                                                            <standard
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Standard"
                                                                value="cmp-teaser--hero--without-image-border-radius"/>
                                                            <roundedcorner
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Rounded Corner"
                                                                value="rounded-corner"/>
                                                            <roundedcorner-two
                                                                jcr:primaryType="nt:unstructured"
                                                                text="Rounded Corner - Variation-2"
                                                                value="cmp-teaser--hero--boeing-checkup"/>
                                                        </items>
                                                    </teaservariation>                                                   
                                                    <addcontainer
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                        fieldDescription="Check to add container component"
                                                        name="./addContainer"
                                                        text="Add Container below form to add component?"
                                                        uncheckedValue="false"
                                                        value="true"/>
                                                </items>
                                            </varitaion-one>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </properties>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
