#
# This file contains the rewrite rules, and can be customized.
#
# By default, it includes just the rewrite rules. You can
# add rewrite rules to this file but you should still include
# the default rewrite rules.

Include conf.d/rewrites/default_rewrite.rules

Include conf.d/rewrites/legacy_rewrite.rules

# rewrite for root redirect
RewriteRule ^/?$ /content/${CONTENT_FOLDER_NAME}/us/en/home.html [PT,L]

#Shorten the URL
RewriteRule ^/content/efe/us/en/(.*).html$ $1 [R=301]
RewriteRule ^(.+)/$ $1/

# Sitemap
RewriteRule ^/sitemap.xml$ /content/${CONTENT_FOLDER_NAME}/us/en.sitemap.xml [PT,L]

# Robots txt
RewriteRule ^/robots.txt$ /content/dam/${CONTENT_FOLDER_NAME}/seo/robots.txt [PT,L]

# Location breadcrumb or location without selector
RewriteRule ^/location$ /locations [R=301,L]

RewriteCond %{REQUEST_URI} !^/apps
RewriteCond %{REQUEST_URI} !^/bin
RewriteCond %{REQUEST_URI} !^/content
RewriteCond %{REQUEST_URI} !^/etc
RewriteCond %{REQUEST_URI} !^/home/
RewriteCond %{REQUEST_URI} !^/libs
RewriteCond %{REQUEST_URI} !^/saml_login
RewriteCond %{REQUEST_URI} !^/system
RewriteCond %{REQUEST_URI} !^/tmp
RewriteCond %{REQUEST_URI} !^/var
RewriteCond %{REQUEST_URI} !(.jpe?g|.png|.svg|.xml|.pdf)$
RewriteRule ^/(.*)$ /content/${CONTENT_FOLDER_NAME}/us/en/$1.html [PT,L]