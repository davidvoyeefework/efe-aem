{
  "pageFrameApi": "$[env:forKey_api;default=https://www.feitest.com/api/v1/pageframe/?namespace=landing-flow]",
  "aggregateApi": "$[env:forKey_api;default=https://www.feitest.com/api/v1/planowners/{Recordkeeper}/aggregate]",
  "forKeyApi": "$[env:forKey_api;default=https://upls-test.edelmanfinancialengines.com/api/v2/planners]",
  "softAuthApi": "$[env:softAuth_api;default=https://upls-test.edelmanfinancialengines.com/api/v2/planners]",
  "signupApi": "$[env:signup_api;default=https://upls-test.edelmanfinancialengines.com/api/v2/planners]",
  "scheduleApi": "$[env:schedule_api;default=https://upls-test.edelmanfinancialengines.com/api/v2/planners]",
  "authenticateApi": "$[env:authenticate_api;default=https://upls-test.edelmanfinancialengines.com/api/v2/planners]",
  "callBackApi": "$[env:callBack_api;default=https://upls-test.edelmanfinancialengines.com/api/v2/planners]",
  "dynamicVariableList": [
    "$[env:aggregate_variables;default=/etc/acs-commons/lists/fe/aggregate-variables|data-aggregate|true]",
    "$[env:authenticationStatus_variables;default=/etc/acs-commons/lists/fe/authenticationstatus-variables|data-authenticationStatus|true]",
    "$[env:keys_variables;default=/etc/acs-commons/lists/fe/keys-variables|data-keys|true]",
    "$[env:pageFrame_variables;default=/etc/acs-commons/lists/fe/pageframe-variables|data-pageFrame|true]"
  ]
}
